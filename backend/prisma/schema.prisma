generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String?  // null for Google-only accounts
  googleId  String?  @unique
  avatarUrl String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipeHistory RecipeHistory[]
  weeklyMenus   WeeklyMenu[]
  favorites     Favorite[]
}

model RecipeHistory {
  id        String   @id @default(cuid())
  name      String
  category  String
  sessionId String?  // anonymous users
  userId    String?  // authenticated users
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([name, sessionId])
  @@unique([name, userId])
  @@index([sessionId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model Recipe {
  id              String   @id @default(cuid())
  name            String
  description     String?
  category        String
  preparationTime Int
  ingredients     Json
  steps           String[]
  pricePerPerson  Float
  nutrition       Json
  userId          String?  // who generated it
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  weeklyMenu   WeeklyMenu? @relation(fields: [weeklyMenuId], references: [id])
  weeklyMenuId String?
  favorites    Favorite[]
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

model Diet {
  id                   String @id @default(cuid())
  name                 String @unique
  emoji                String
  description          String
  forbiddenIngredients Json   // String[]
}

model WeeklyMenu {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  mealsCount   Int
  personsCount Int
  recipes      Recipe[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ExcludedTag {
  id     String  @id @default(cuid())
  name   String
  userId String?

  @@unique([name, userId])
}

model BlacklistedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String?
  bannedBy  String   // admin user id
  createdAt DateTime @default(now())
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}
